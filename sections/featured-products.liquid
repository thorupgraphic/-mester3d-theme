<section class="products-section">
  <h2>{{ section.settings.heading }}</h2>
  <p class="products-subheading">{{ section.settings.subheading }}</p>

  <div class="product-grid">
    {% assign colors = 'dark,orange,yellow' | split: ',' %}
    {% for product in collections.featured.products limit: section.settings.product_limit %}
      {% assign color_index = forloop.index0 | modulo: 3 %}
      {% assign card_color = colors[color_index] %}
      <a href="{{ product.url }}" class="product-card">
        <div class="product-image card-{{ card_color }}">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title }}" loading="lazy">
          {% else %}
            <span class="placeholder-icon">📦</span>
          {% endif %}
        </div>
        <div class="product-info">
          <div class="product-title">{{ product.title }}</div>
          <div class="product-price">{{ product.price | money }}</div>
          <span class="btn-small">Se produkt</span>
        </div>
      </a>
    {% else %}
      {% for i in (1..4) %}
        {% assign color_index = forloop.index0 | modulo: 3 %}
        {% assign card_color = colors[color_index] %}
        <div class="product-card">
          <div class="product-image card-{{ card_color }}">
            <span class="placeholder-icon">📦</span>
          </div>
          <div class="product-info">
            <div class="product-title">Eksempel produkt</div>
            <div class="product-price">199 kr</div>
            <span class="btn-small">Se produkt</span>
          </div>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Udvalgte produkter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Vores kreationer"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "Fra fantasifulde figurer til hverdagens funktionelle helte"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Antal produkter",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Udvalgte produkter"
    }
  ]
}
{% endschema %}
