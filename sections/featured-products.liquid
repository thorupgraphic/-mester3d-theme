<style>
  .featured-products {
    padding: 5rem 1.5rem;
    background: #fafafa;
  }

  .featured-container {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    animation: slideInDown 0.8s ease-out;
  }

  .section-header h2 {
    font-size: 2.5rem;
    color: var(--color-accent);
    margin-bottom: 1rem;
    font-weight: 800;
  }

  .section-header p {
    font-size: 1.1rem;
    color: #666;
    line-height: 1.6;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease;
    animation: slideInUp 0.6s ease-out forwards;
    opacity: 0;
  }

  .product-card:nth-child(1) { animation-delay: 0.1s; }
  .product-card:nth-child(2) { animation-delay: 0.2s; }
  .product-card:nth-child(3) { animation-delay: 0.3s; }
  .product-card:nth-child(4) { animation-delay: 0.4s; }
  .product-card:nth-child(n+5) { animation-delay: 0.5s; }

  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .product-image {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background: linear-gradient(135deg, #f0f0f0 0%, #e0e0e0 100%);
    overflow: hidden;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card:hover .product-image img {
    transform: scale(1.08);
  }

  .product-info {
    padding: 1.5rem;
  }

  .product-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    min-height: 2.2rem;
    line-height: 1.1;
  }

  .product-price {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .product-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-accent);
    color: var(--color-primary);
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    border: 2px solid var(--color-accent);
  }

  .product-link:hover {
    background: var(--color-primary);
    color: var(--color-accent);
  }

  @media (max-width: 1024px) {
    .section-header h2 {
      font-size: 2rem;
    }

    .product-grid {
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .featured-products {
      padding: 3rem 1.5rem;
    }

    .section-header {
      margin-bottom: 2.5rem;
    }

    .section-header h2 {
      font-size: 1.75rem;
    }

    .section-header p {
      font-size: 1rem;
    }

    .product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .product-info {
      padding: 1rem;
    }
  }

  @media (max-width: 480px) {
    .product-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>

<section class="featured-products">
  <div class="featured-container">
    <div class="section-header">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
    </div>

    <div class="product-grid">
      {% for product in collections.featured.products limit: section.settings.product_limit %}
        <div class="product-card">
          <div class="product-image">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 500 }}"
                alt="{{ product.title }}"
                loading="lazy"
              >
            {% else %}
              <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1rem;">
                <span style="font-size: 3rem;">📦</span>
                <span style="color: #999; font-size: 0.9rem;">Intet billede</span>
              </div>
            {% endif %}
          </div>
          <div class="product-info">
            <h3 class="product-title">{{ product.title }}</h3>
            <div class="product-price">{{ product.price | money_with_currency }}</div>
            <a href="{{ product.url }}" class="product-link">
              Se detaljer →
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Udvalgte Produkter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Vores Kreationer"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Beskrivelse",
      "default": "Håndværk møder teknologi"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Antal produkter",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Udvalgte Produkter"
    }
  ]
}
{% endschema %}
