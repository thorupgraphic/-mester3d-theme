<style>
  .footer {
    background: linear-gradient(135deg, var(--color-accent) 0%, #1a1a1a 100%);
    color: white;
    padding: 4rem 1.5rem 2rem;
    margin-top: 4rem;
    border-top: 2px solid var(--color-primary);
  }

  .footer-container {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-section {
    animation: fadeIn 0.8s ease-out;
  }

  .footer-section h3 {
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .footer-section p {
    font-size: 0.95rem;
    opacity: 0.9;
    line-height: 1.8;
  }

  .footer-section a {
    color: white;
    text-decoration: none;
    transition: color 0.3s;
    font-weight: 500;
  }

  .footer-section a:hover {
    color: var(--color-primary);
  }

  .footer-section ul {
    list-style: none;
  }

  .footer-section ul li {
    margin-bottom: 0.75rem;
  }

  .footer-section ul li a {
    font-size: 0.95rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    font-size: 1.5rem;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 215, 0, 0.15);
    border-radius: 50%;
    transition: all 0.3s ease;
  }

  .social-links a:hover {
    background: var(--color-primary);
    color: var(--color-accent);
    transform: translateY(-3px);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-top: 2rem;
    text-align: center;
    opacity: 0.85;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 3rem 1.5rem 1.5rem;
      margin-top: 3rem;
    }

    .footer-content {
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .footer-section h3 {
      font-size: 1.1rem;
    }
  }
</style>

<footer class="footer">
  <div class="footer-container">
    <div class="footer-content">
      <div class="footer-section">
        <h3>🖨️ Mester3D</h3>
        <p>Håndværk møder teknologi. Vi skaber 3D-printede produkter med sjæl og dedikation til hvert enkelt stykke.</p>
      </div>
      <div class="footer-section">
        <h3>Genveje</h3>
        <ul>
          <li><a href="/">Hjem</a></li>
          <li><a href="/collections/all">Alle produkter</a></li>
          <li><a href="/cart">Handlevogn</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h3>Følg os</h3>
        <div class="social-links">
          <a href="https://instagram.com/mester3d" target="_blank" rel="noopener" title="Instagram">📱</a>
          <a href="https://facebook.com/mester3d" target="_blank" rel="noopener" title="Facebook">👍</a>
          <a href="https://tiktok.com/@mester3d" target="_blank" rel="noopener" title="TikTok">🎵</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Mester3D A/S. Alle rettigheder forbeholdt.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer"
}
{% endschema %}
