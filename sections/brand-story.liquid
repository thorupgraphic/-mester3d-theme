<style>
  .brand-story {
    padding: 100px 20px;
    background: white;
  }

  .story-container {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .story-content h2 {
    font-size: 2.5rem;
    color: #000;
    margin-bottom: 20px;
    line-height: 1.3;
  }

  .story-content p {
    font-size: 1.1rem;
    color: #555;
    margin-bottom: 20px;
    line-height: 1.8;
  }

  .story-highlight {
    background: linear-gradient(90deg, #FFD700 0%, #FF8C00 100%);
    padding: 30px;
    border-radius: 10px;
    margin: 30px 0;
    color: #000;
  }

  .story-highlight strong {
    font-weight: 700;
  }

  .story-image {
    position: relative;
  }

  .story-image img {
    width: 100%;
    border-radius: 15px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
  }

  .story-badge {
    position: absolute;
    top: -20px;
    right: -20px;
    background: #FFD700;
    color: #000;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-weight: 700;
    font-size: 1.1rem;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 768px) {
    .brand-story {
      padding: 50px 20px;
    }

    .story-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .story-content h2 {
      font-size: 2rem;
    }

    .story-badge {
      width: 100px;
      height: 100px;
      font-size: 0.9rem;
      top: -15px;
      right: -15px;
    }
  }
</style>

<section class="brand-story">
  <div class="story-container">
    <div class="story-content">
      <h2>{{ section.settings.heading }}</h2>

      {% for block in section.blocks %}
        {% if block.type == 'text' %}
          <p>{{ block.settings.text }}</p>
        {% elsif block.type == 'highlight' %}
          <div class="story-highlight">
            {{ block.settings.highlight_text }}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="story-image">
      {% if section.settings.image %}
        <img src="{{ section.settings.image | image_url: width: 500 }}" alt="Mester3D historie">
      {% else %}
        <div style="width: 100%; height: 400px; background: #f0f0f0; border-radius: 15px; display: flex; align-items: center; justify-content: center;">
          <span style="color: #999; font-size: 4rem;">🖨️</span>
        </div>
      {% endif %}

      <div class="story-badge">
        {{ section.settings.badge_text }}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Histoire",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Håndværk møder Teknologi"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Billede"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge tekst",
      "default": "Skabt med passion"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Tekst",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Tekst indhold",
          "default": "Vi på Mester3D tror på, at 3D-printing ikke kun er teknologi – det er en kunstform. Hver enkelt produkt er designet med tanke for detalje og lavet med passion."
        }
      ]
    },
    {
      "type": "highlight",
      "name": "Fremhævet tekst",
      "settings": [
        {
          "type": "textarea",
          "id": "highlight_text",
          "label": "Fremhævet tekst",
          "default": "<strong>Vi skaber ikke bare produkter,</strong> vi skaber oplevelser der inspirerer til kreativitet og viser, hvad der er muligt."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Historie"
    }
  ]
}
{% endschema %}
