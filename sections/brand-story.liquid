<section class="story-section">
  <div class="story-text">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.paragraph_1 }}</p>
    <p>{{ section.settings.paragraph_2 }}</p>
  </div>
  <div class="story-badges">
    {% for block in section.blocks %}
      <div class="story-badge">
        <span class="badge-icon">{{ block.settings.icon }}</span>
        <span>{{ block.settings.text }}</span>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Brand historie",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Håndværk møder teknologi"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Afsnit 1",
      "default": "Hos Mester3D tror vi på, at 3D-print er mere end teknologi – det er et håndværk. Hver figur, hver detalje og hvert lag bliver printet med omhu og kærlighed til faget."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Afsnit 2",
      "default": "Ingen fast kategori, ingen begrænsninger. Kun fantasi, skaberkraft og masser af filament."
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Ikon (emoji)",
          "default": "✋"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "100% håndtjekket finish"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "badge",
        "settings": {
          "icon": "✋",
          "text": "100% håndtjekket finish"
        }
      },
      {
        "type": "badge",
        "settings": {
          "icon": "💡",
          "text": "Skræddersyet til din idé"
        }
      },
      {
        "type": "badge",
        "settings": {
          "icon": "🌱",
          "text": "Bæredygtigt filament"
        }
      }
    ]
  },
  "presets": [
    {
      "name": "Brand historie",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon": "✋",
            "text": "100% håndtjekket finish"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "💡",
            "text": "Skræddersyet til din idé"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "🌱",
            "text": "Bæredygtigt filament"
          }
        }
      ]
    }
  ]
}
{% endschema %}
