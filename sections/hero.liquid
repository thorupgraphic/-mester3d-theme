<section class="hero">
  <div class="hero-text">
    <span class="hero-badge">{{ section.settings.badge_text }}</span>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.cta_link }}" class="btn btn-dark">
      {{ section.settings.cta_text }} →
    </a>
  </div>
  <div class="hero-mascot">
    {% render 'mr3d-mascot' %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge tekst",
      "default": "HÅNDVÆRK MØDER TEKNOLOGI"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Lad det blive skabt"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "3D-printede figurer, dekorationer og custom-genstande – skabt med passion, lag for lag, af Mester3D."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Knap tekst",
      "default": "Se vores kreationer"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Knap link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
