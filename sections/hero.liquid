<style>
  .hero {
    background: linear-gradient(135deg, {{ section.settings.bg_color_1 }} 0%, {{ section.settings.bg_color_2 }} 100%);
    padding: 80px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-content {
    max-width: 1000px;
    z-index: 2;
    animation: fadeInUp 0.8s ease-out;
  }

  .hero-mascot {
    width: 200px;
    height: 200px;
    margin: 0 auto 30px;
    animation: bounce 2s infinite;
  }

  .hero-mascot img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .hero h1 {
    font-size: 3.5rem;
    color: {{ section.settings.text_color }};
    margin: 20px 0;
    font-weight: 800;
    line-height: 1.2;
  }

  .hero p {
    font-size: 1.25rem;
    color: {{ section.settings.text_color }};
    margin-bottom: 40px;
    opacity: 0.95;
  }

  .hero-cta {
    display: inline-block;
    background: {{ section.settings.cta_color }};
    color: white;
    padding: 18px 45px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .hero-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 50px 20px;
      min-height: 400px;
    }

    .hero h1 {
      font-size: 2.5rem;
    }

    .hero p {
      font-size: 1rem;
    }

    .hero-mascot {
      width: 150px;
      height: 150px;
    }
  }
</style>

<section class="hero">
  <div class="hero-content">
    {% if section.settings.mascot %}
      <div class="hero-mascot">
        <img src="{{ section.settings.mascot | image_url: width: 400 }}" alt="Mr. 3D">
      </div>
    {% endif %}

    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>

    <a href="{{ section.settings.cta_link }}" class="hero-cta">
      {{ section.settings.cta_text }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "mascot",
      "label": "Mr. 3D mascot billede"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Lad det blive skabt!"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "3D-printede produkter med sjæl og skaberkraft"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA tekst",
      "default": "Se vores kreationer"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link",
      "default": "/collections/all"
    },
    {
      "type": "color",
      "id": "bg_color_1",
      "label": "Gradient farve 1",
      "default": "#FFD700"
    },
    {
      "type": "color",
      "id": "bg_color_2",
      "label": "Gradient farve 2",
      "default": "#FF8C00"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Tekst farve",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "CTA button farve",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
