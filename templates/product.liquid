<style>
  .product-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 32px;
  }

  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .product-page-image {
    width: 100%;
    aspect-ratio: 1;
    background: #fafafa;
    border-radius: 12px;
    overflow: hidden;
  }

  .product-page-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-page-details h1 {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 14px;
  }

  .product-page-price {
    font-size: 22px;
    color: #FF8C00;
    font-weight: 700;
    margin-bottom: 24px;
  }

  .product-page-description {
    margin-bottom: 28px;
    line-height: 1.8;
    color: #444;
  }

  .add-to-cart-form {
    display: flex;
    gap: 12px;
  }

  .add-to-cart-form input[type="number"] {
    width: 70px;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 8px;
  }

  .add-to-cart-form button {
    background: #111;
    color: #FFD700;
    border: none;
    padding: 14px 32px;
    border-radius: 30px;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .product-page {
      padding: 32px 20px;
    }
  }
</style>

<div class="product-page">
  <div class="product-layout">
    <div class="product-page-image">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}">
      {% endif %}
    </div>
    <div class="product-page-details">
      <h1>{{ product.title }}</h1>
      <div class="product-page-price">{{ product.price | money }}</div>
      <div class="product-page-description">{{ product.description }}</div>
      <form action="/cart/add" method="post" class="add-to-cart-form">
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        <input type="number" name="quantity" value="1" min="1">
        <button type="submit">Tilføj til kurv</button>
      </form>
    </div>
  </div>
</div>
