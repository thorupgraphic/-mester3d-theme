<div class="container" style="max-width: 900px;">
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 40px;">
    <div>
      {% if product.featured_image %}
        <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title }}" style="width: 100%; border-radius: 8px;">
      {% endif %}
    </div>
    <div>
      <h1>{{ product.title }}</h1>
      <p style="font-size: 24px; color: #FF8C00; font-weight: bold; margin: 20px 0;">{{ product.price | money }}</p>
      <p>{{ product.description }}</p>

      <form action="/cart/add" method="post" style="margin: 30px 0;">
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        <div style="display: flex; gap: 10px; align-items: center;">
          <label>Antal:</label>
          <input type="number" name="quantity" value="1" min="1" style="width: 60px; padding: 8px; border: 1px solid #ddd;">
          <button type="submit" style="background: #111; color: #FFD700; border: none; padding: 10px 30px; border-radius: 4px; font-weight: bold; cursor: pointer;">Tilføj til kurv</button>
        </div>
      </form>

      <a href="/collections/all" style="color: #FF8C00; text-decoration: none; font-weight: bold;">← Tilbage til produkter</a>
    </div>
  </div>
</div>
