<section class="hero">
  <h1>Lad det blive skabt!</h1>
  <p>3D-printede produkter med sjæl og skaberkraft</p>
  <a href="/collections/all">Se vores kreationer</a>
</section>

<section class="products">
  <h2>Vores Kreationer</h2>
  <div class="product-grid">
    {% for product in collections.featured.products limit: 8 %}
      <div class="product-card">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}">
        {% else %}
          <div style="width: 100%; height: 250px; background: #f0f0f0; display: flex; align-items: center; justify-content: center;">
            <span style="color: #999;">📦</span>
          </div>
        {% endif %}
        <div class="product-info">
          <h3>{{ product.title }}</h3>
          <div class="price">{{ product.price | money }}</div>
          <a href="{{ product.url }}">Se produkt</a>
        </div>
      </div>
    {% endfor %}
  </div>
</section>
