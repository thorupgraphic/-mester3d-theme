<style>
  .collection-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 32px;
  }

  .collection-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .collection-header h1 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .collection-header p {
    color: #666;
  }

  @media (max-width: 768px) {
    .collection-page {
      padding: 32px 20px;
    }

    .collection-header h1 {
      font-size: 24px;
    }
  }
</style>

<div class="collection-page">
  <div class="collection-header">
    <h1>{{ collection.title }}</h1>
    {% if collection.description %}
      <p>{{ collection.description }}</p>
    {% endif %}
  </div>

  <div class="product-grid">
    {% assign colors = 'dark,orange,yellow' | split: ',' %}
    {% for product in collection.products %}
      {% assign color_index = forloop.index0 | modulo: 3 %}
      {% assign card_color = colors[color_index] %}
      <a href="{{ product.url }}" class="product-card">
        <div class="product-image card-{{ card_color }}">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title }}" loading="lazy">
          {% else %}
            <span class="placeholder-icon">📦</span>
          {% endif %}
        </div>
        <div class="product-info">
          <div class="product-title">{{ product.title }}</div>
          <div class="product-price">{{ product.price | money }}</div>
          <span class="btn-small">Se produkt</span>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
