<div class="container">
  <h1 style="margin-top: 40px; margin-bottom: 10px;">{{ collection.title }}</h1>
  {% if collection.description %}<p style="margin-bottom: 40px; color: #666;">{{ collection.description }}</p>{% endif %}

  <div class="products">
    {% for product in collection.products %}
      <div class="product">
        <div class="product-img">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}" style="width:100%; height:100%; object-fit:cover;">
          {% else %}
            📦
          {% endif %}
        </div>
        <div class="product-info">
          <div class="product-title">{{ product.title }}</div>
          <div class="product-price">{{ product.price | money }}</div>
          <a href="{{ product.url }}">Køb nu</a>
        </div>
      </div>
    {% endfor %}
  </div>
</div>
